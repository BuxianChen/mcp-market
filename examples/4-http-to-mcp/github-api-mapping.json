{
  "name": "GitHub API Mappings",
  "description": "GitHub REST API 的 HTTP 转 MCP 配置示例",
  "baseUrl": "https://api.github.com",
  "tools": [
    {
      "toolName": "get_user",
      "description": "获取 GitHub 用户信息",
      "httpMethod": "GET",
      "httpPath": "/users/{username}",
      "parameters": {
        "username": {
          "type": "string",
          "description": "GitHub 用户名",
          "location": "path",
          "required": true
        }
      },
      "responseMapping": {
        "login": "$.login",
        "name": "$.name",
        "bio": "$.bio",
        "public_repos": "$.public_repos",
        "followers": "$.followers",
        "following": "$.following",
        "created_at": "$.created_at"
      }
    },
    {
      "toolName": "get_user_repos",
      "description": "获取用户的公开仓库列表",
      "httpMethod": "GET",
      "httpPath": "/users/{username}/repos",
      "parameters": {
        "username": {
          "type": "string",
          "description": "GitHub 用户名",
          "location": "path",
          "required": true
        },
        "sort": {
          "type": "string",
          "description": "排序方式: created, updated, pushed, full_name",
          "location": "query",
          "required": false
        },
        "per_page": {
          "type": "number",
          "description": "每页返回数量（最大 100）",
          "location": "query",
          "required": false
        }
      },
      "responseMapping": {
        "repositories": "$[*].{name: name, description: description, stars: stargazers_count, language: language, url: html_url}"
      }
    },
    {
      "toolName": "get_repo",
      "description": "获取指定仓库的详细信息",
      "httpMethod": "GET",
      "httpPath": "/repos/{owner}/{repo}",
      "parameters": {
        "owner": {
          "type": "string",
          "description": "仓库所有者",
          "location": "path",
          "required": true
        },
        "repo": {
          "type": "string",
          "description": "仓库名称",
          "location": "path",
          "required": true
        }
      },
      "responseMapping": {
        "name": "$.name",
        "full_name": "$.full_name",
        "description": "$.description",
        "stars": "$.stargazers_count",
        "forks": "$.forks_count",
        "language": "$.language",
        "open_issues": "$.open_issues_count",
        "created_at": "$.created_at",
        "updated_at": "$.updated_at",
        "url": "$.html_url"
      }
    },
    {
      "toolName": "search_repositories",
      "description": "搜索 GitHub 仓库",
      "httpMethod": "GET",
      "httpPath": "/search/repositories",
      "parameters": {
        "q": {
          "type": "string",
          "description": "搜索关键词（支持 GitHub 搜索语法）",
          "location": "query",
          "required": true
        },
        "sort": {
          "type": "string",
          "description": "排序字段: stars, forks, updated",
          "location": "query",
          "required": false
        },
        "order": {
          "type": "string",
          "description": "排序顺序: asc, desc",
          "location": "query",
          "required": false
        },
        "per_page": {
          "type": "number",
          "description": "每页返回数量（最大 100）",
          "location": "query",
          "required": false
        }
      },
      "responseMapping": {
        "total_count": "$.total_count",
        "repositories": "$.items[*].{name: name, owner: owner.login, description: description, stars: stargazers_count, language: language, url: html_url}"
      }
    },
    {
      "toolName": "get_repo_readme",
      "description": "获取仓库的 README 内容",
      "httpMethod": "GET",
      "httpPath": "/repos/{owner}/{repo}/readme",
      "parameters": {
        "owner": {
          "type": "string",
          "description": "仓库所有者",
          "location": "path",
          "required": true
        },
        "repo": {
          "type": "string",
          "description": "仓库名称",
          "location": "path",
          "required": true
        }
      },
      "responseMapping": {
        "name": "$.name",
        "path": "$.path",
        "download_url": "$.download_url",
        "content": "$.content"
      }
    }
  ],
  "headers": {
    "Accept": "application/vnd.github+json",
    "X-GitHub-Api-Version": "2022-11-28"
  },
  "notes": [
    "GitHub API 有速率限制：未认证请求 60 次/小时，认证请求 5000 次/小时",
    "如需认证，添加 Authorization header: 'Bearer YOUR_GITHUB_TOKEN'",
    "README 内容是 Base64 编码的，需要解码后使用"
  ],
  "usage": {
    "setup": [
      "1. 在 MCP Market 中创建 HTTP 类型的服务器",
      "2. URL 填写: https://api.github.com",
      "3. （可选）配置 Headers 添加认证 token",
      "4. 点击'配置映射'按钮，逐个添加上述工具配置"
    ],
    "examples": [
      {
        "tool": "get_user",
        "arguments": {
          "username": "torvalds"
        },
        "description": "获��� Linus Torvalds 的 GitHub 信息"
      },
      {
        "tool": "get_user_repos",
        "arguments": {
          "username": "torvalds",
          "sort": "updated",
          "per_page": 10
        },
        "description": "获取 Linus 最近更新的 10 个仓库"
      },
      {
        "tool": "get_repo",
        "arguments": {
          "owner": "torvalds",
          "repo": "linux"
        },
        "description": "获取 Linux 内核仓库信息"
      },
      {
        "tool": "search_repositories",
        "arguments": {
          "q": "language:python stars:>1000",
          "sort": "stars",
          "order": "desc",
          "per_page": 10
        },
        "description": "搜索 Python 项目，按 star 数排序"
      }
    ]
  }
}
